{
  "manifest_version": 3,
  "name": "Hotmail Register Luckmail V2",
  "version": "0.2.0",
  "description": "V2 版：使用固定 Hotmail 账号池和 Luckmail API 自动执行 OpenAI OAuth 注册流程",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab",
    "cookies",
    "debugger",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Hotmail Register Luckmail V2",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://auth0.openai.com/*",
        "https://auth.openai.com/*",
        "https://accounts.openai.com/*"
      ],
      "js": [
        "content/utils.js",
        "content/get-code.js",
        "shared/oauth-step-helpers-runtime.js",
        "shared/login-strategy-runtime.js",
        "shared/oauth-step-helpers.js",
        "content/signup-page.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
